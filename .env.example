# Local MongoDB (docker-compose service, bound to 127.0.0.1)
MONGODB_URI=mongodb://127.0.0.1:27017/tosin4dev

# Discord webhook for blocked / review_ready pings (optional; leave blank to disable)
DISCORD_WEBHOOK_URL=

# Dev server bind host. Reachable from the SSH Windows client
# (192.168.0.248 → Linux host 192.168.0.68).
# 0.0.0.0 listens on all interfaces (no /etc/hosts edit needed) → http://192.168.0.68:3141
# To use a hostname slug instead, run on the host (needs sudo):
#   echo '127.0.0.1 t4d-0.localhost' | sudo tee -a /etc/hosts
# then set DEV_HOST=t4d-0.localhost
DEV_HOST=0.0.0.0
